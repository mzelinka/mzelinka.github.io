@article{blanchard-wrigglesworth_record_2025,
	title = {Record {Warmth} of 2023 and 2024 was {Highly} {Predictable} and {Resulted} {From} {ENSO} {Transition} and {Northern} {Hemisphere} {Absorbed} {Shortwave} {Anomalies}},
