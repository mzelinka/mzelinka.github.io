	pages = {e2024AV001636},
	file = {Full Text PDF:/Users/zelinka1/Zotero default/storage/ZT2VMLGM/Mauritsen et al. - 2025 - Earth's Energy Imbalance More Than Doubled in Recent Decades.pdf:application/pdf},
