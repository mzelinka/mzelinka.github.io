@article{myers_cloud_2018,
	title = {Cloud {Feedback} {Key} to {Marine} {Heatwave} off {Baja} {California}},
	volume = {45},
	issn = {1944-8007},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1029/2018GL078242},
	doi = {10.1029/2018GL078242},
	abstract = {Between 2013 and 2015, the northeast Pacific Ocean experienced the warmest surface temperature anomalies in the modern observational record. This “marine heatwave” marked a shift of Pacific decadal variability to its warm phase and was linked to significant impacts on marine species as well as exceptionally arid conditions in western North America. Here we show that the subtropical signature of this warming, off Baja California, was associated with a record deficit in the spatial coverage of co-located marine boundary layer clouds. This deficit coincided with a large increase in downwelling solar radiation that dominated the anomalous energy budget of the upper ocean, resulting in record-breaking warm sea surface temperature anomalies. Our observation-based analysis suggests that a positive cloud-surface temperature feedback was key to the extreme intensity of the heatwave. The results demonstrate the extent to which boundary layer clouds can contribute to regional variations in climate.},
	language = {en},
	number = {9},
	urldate = {2023-04-19},
	journal = {Geophysical Research Letters},
	author = {Myers, Timothy A. and Mechoso, Carlos R. and Cesana, Gregory V. and DeFlorio, Michael J. and Waliser, Duane E.},
	year = {2018},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1029/2018GL078242},
	pages = {4345--4352},
	file = {Snapshot:/Users/zelinka1/Zotero default/storage/CBVYQX83/2018GL078242.html:text/html},
}

@article{radel_amplification_2016,
	title = {Amplification of {El} {Niño} by cloud longwave coupling to atmospheric circulation},
	volume = {9},
	copyright = {2016 Nature Publishing Group},
	issn = {1752-0908},
	url = {https://www.nature.com/articles/ngeo2630},
	doi = {10.1038/ngeo2630},
	abstract = {The El Niño/Southern Oscillation (ENSO) affects weather patterns worldwide. Numerical experiments with an Earth system model suggest that cloud feedbacks act to amplify ENSO variability by a factor of two or more.},
	language = {en},
	number = {2},
